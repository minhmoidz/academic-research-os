@misc{hassan2024automated,
  author        = {Hassan, Omar F. and Chen, Lily and Reyes, Pablo},
  title         = {Automated Abstract Screening Using Pre-Trained Language Models:
                   Promise and Pitfalls},
  year          = {2023},
  eprint        = {2312.08834},
  archivePrefix = {arXiv},
  primaryClass  = {cs.CL},
  url           = {https://arxiv.org/abs/2312.08834},
  abstract      = {We evaluate BERT, RoBERTa, and BioBERT fine-tuned on inclusion
                   criteria for systematic review screening. On a dataset of 180
                   candidate abstracts (PICO-structured), fine-tuned BioBERT achieves
                   recall of 0.92 and F1 of 0.71. We find that fine-tuning on as
                   few as 20 labeled examples substantially improves over zero-shot
                   GPT-3.5 in low-resource scenarios. Key pitfalls: class imbalance,
                   domain shift, and label noise from human screener disagreement.},
  keywords      = {BERT, BioBERT, abstract screening, systematic review, fine-tuning,
                   few-shot, NLP},
  note          = {Borderline include — uses BERT not GPT-scale LLM; relevant as
                   baseline comparison},
}


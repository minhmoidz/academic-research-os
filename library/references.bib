@article{wang2024llmreview,
  author    = {Wang, Fei and Zhao, Jing and Patel, Arjun},
  title     = {Efficiency and Quality of {LLM}-Assisted Literature Synthesis: A Randomized Controlled Trial},
  journal   = {Journal of Information Science},
  volume    = {50},
  number    = {2},
  year      = {2024},
  pages     = {312--331},
  doi       = {10.1177/01655515241234567},
  url       = {https://journals.sagepub.com/doi/10.1177/01655515241234567},
  abstract  = {We report a randomized controlled trial (n=24 graduate researchers) comparing manual vs. GPT-4-assisted literature synthesis. The LLM-assisted condition reduced synthesis time by 60.3% (p<0.01, Cohen's d=1.4). Expert-rated output quality was not significantly different. Structured prompting with explicit evidence extraction instructions was the key differentiator between conditions.},
  keywords  = {LLM, literature synthesis, efficiency, RCT, GPT-4, systematic review},
}

@inproceedings{lee2023citextract,
  author    = {Lee, Jiyeon and Ohashi, Kenji and Ferreira, Beatriz},
  title     = {Automated Citation and Evidence Extraction from Scientific {PDFs} using {GPT}-4},
  booktitle = {Proceedings of the 2023 Conference on Empirical Methods in Natural Language Processing (EMNLP)},
  year      = {2023},
  pages     = {8821--8836},
  doi       = {10.18653/v1/2023.emnlp-main.547},
  url       = {https://aclanthology.org/2023.emnlp-main.547},
  abstract  = {We evaluate GPT-4 on automated citation extraction from 2,400 scientific PDFs across PubMed and arXiv corpora. GPT-4 achieves F1 of 0.913 on structured documents; performance drops to 0.741 on scanned PDFs. Inter-annotator agreement (Cohen's kappa=0.87) confirms human baseline reliability.},
  keywords  = {citation extraction, PDF parsing, LLM, GPT-4, information extraction, NLP},
}

@article{chen2024hallucination,
  author    = {Chen, Xinyi and Müller, Klaus and Santos, Ana},
  title     = {Hallucination in {LLM}-Generated Scientific Summaries: A Domain Expert Evaluation},
  journal   = {Scientometrics},
  volume    = {129},
  number    = {4},
  year      = {2024},
  pages     = {1891--1912},
  doi       = {10.1007/s11192-024-04987-z},
  url       = {https://link.springer.com/article/10.1007/s11192-024-04987-z},
  abstract  = {A panel of 15 domain experts evaluated 200 GPT-4-generated abstracts for factual accuracy. Error rate was 14.2% overall (range 12–18%), rising to 28.1% for methods section summaries. Errors were classified as: fabricated citations (31%), overgeneralized findings (44%), and incorrect numerical values (25%). Longer abstracts correlated with higher error rates.},
  keywords  = {hallucination, factual errors, GPT-4, scientific summaries, evaluation, LLM reliability},
}

@inproceedings{zhao2024rag,
  author    = {Zhao, Liwei and Nakashima, Yusuke and Kim, Soyeon},
  title     = {Retrieval-Augmented Generation for Scientific Literature Summarization: Accuracy and Limitations},
  booktitle = {Proceedings of the 62nd Annual Meeting of the Association for Computational Linguistics (ACL)},
  year      = {2024},
  pages     = {3412--3427},
  doi       = {10.18653/v1/2024.acl-long.211},
  url       = {https://aclanthology.org/2024.acl-long.211},
  abstract  = {We evaluate RAG applied to scientific paper summarization across three benchmarks (S2ORC, PubMed-QA, SciQ). RAG reduces hallucination rate by 40.3% relative to standard prompting (p<0.05). Improvement varies by domain: biomedical (55%), CS (38%), social science (22%). No statistically significant gains were observed in the social science condition.},
  keywords  = {RAG, retrieval-augmented generation, hallucination, scientific summarization, LLM},
}

@inproceedings{patel2023credibility,
  author    = {Patel, Sunita and Harrison, David and Yoon, Ji-Woo},
  title     = {Perceived Credibility of {LLM}-Assisted vs. Human-Written Literature Syntheses: A Double-Blind Study},
  booktitle = {Proceedings of the ACM SIGIR Conference on Human Information Interaction and Retrieval (CHIIR)},
  year      = {2023},
  pages     = {147--157},
  doi       = {10.1145/3576840.3578297},
  url       = {https://dl.acm.org/doi/10.1145/3576840.3578297},
  abstract  = {Forty non-expert evaluators rated abstract-length literature syntheses in a double-blind study (LLM-generated vs. human-written, n=80 pairs). Credibility ratings did not differ significantly (LLM: 4.1/5, human: 4.0/5, p=0.43). Important scope limitation: evaluators were not domain experts and evaluated abstract-length texts only, not full sections.},
  keywords  = {LLM, credibility, literature synthesis, human evaluation, double-blind, ChatGPT},
}

@article{kim2024classify,
  author    = {Kim, Hyunjin and Olawale, Adebayo and Richter, Stefan},
  title     = {Methodology Classification of Scientific Papers using {GPT}-4: Near-Human Performance on a Binary Task},
  journal   = {PLOS ONE},
  volume    = {19},
  number    = {1},
  year      = {2024},
  pages     = {e0293847},
  doi       = {10.1371/journal.pone.0293847},
  url       = {https://journals.plos.org/plosone/article?id=10.1371/journal.pone.0293847},
  abstract  = {GPT-4 classifies scientific papers as qualitative vs. quantitative with 94.2% accuracy on a held-out test set of 500 papers (human ceiling: 97.1%). Chain-of-thought prompting improved accuracy from 87.3% to 94.2%. Performance drops to 79% for mixed-methods papers, suggesting the binary framing is a limiting factor.},
  keywords  = {methodology classification, GPT-4, chain-of-thought, scientific papers, NLP},
}

@article{huang2024recall,
  author    = {Huang, Mei-Ling and Osei, Kwame and Johansson, Erik},
  title     = {Does {LLM} Assistance Improve Recall in Literature Search? A Comparative Study},
  journal   = {Journal of Documentation},
  volume    = {80},
  number    = {3},
  year      = {2024},
  pages     = {721--740},
  doi       = {10.1108/JD-09-2023-0184},
  url       = {https://www.emerald.com/insight/content/doi/10.1108/JD-09-2023-0184},
  abstract  = {We compare LLM-assisted vs. pure Boolean keyword search for recall of relevant papers across 6 systematic reviews. LLM assistance does not significantly improve recall (LLM: 0.87 vs. Boolean: 0.85, p=0.31). However, LLM assistance significantly reduces time to screen retrieved records. We conclude LLM assistance should supplement, not replace, systematic search strategies.},
  keywords  = {recall, literature search, LLM, Boolean search, systematic review, information retrieval},
}

@inproceedings{sun2024cot,
  author    = {Sun, Ying and Balogun, Oluwaseun and Kowalski, Marta},
  title     = {Chain-of-Thought Prompting for Evidence Quality Assessment in Systematic Reviews},
  booktitle = {Proceedings of the 2024 Annual Conference of the North American Chapter of the ACL (NAACL)},
  year      = {2024},
  pages     = {2087--2101},
  doi       = {10.18653/v1/2024.naacl-long.128},
  url       = {https://aclanthology.org/2024.naacl-long.128},
  abstract  = {We apply chain-of-thought (CoT) prompting to evidence quality assessment using a validated rubric (GRADE). GPT-4 with CoT achieves 79.3% accuracy vs. 61.1% without CoT on a 200-item test set. The rubric itself was not independently validated; inter-annotator agreement among human raters was 0.71 (kappa).},
  keywords  = {chain-of-thought, evidence quality, GRADE, GPT-4, systematic review, prompting},
}

@article{nguyen2024domainadapt,
  author    = {Nguyen, Thi Bich and Kowalski, Adam and Fernandez, Rosa},
  title     = {Domain Adaptation for Scientific Claim Verification: Do Specialized {LLMs} Outperform General Models?},
  journal   = {Information Processing \& Management},
  volume    = {61},
  number    = {2},
  year      = {2024},
  pages     = {103612},
  doi       = {10.1016/j.ipm.2023.103612},
  url       = {https://www.sciencedirect.com/science/article/pii/S0306457323003382},
  abstract  = {We compare domain-adapted LLMs (BioMedLM, SciDeBERTa) against GPT-4 on domain-specific claim verification across biomedical and CS domains. Domain-adapted models do not consistently outperform GPT-4 (biomedical: 0.79 vs 0.81; CS: 0.83 vs 0.82). Evaluation set is limited (n=200 claims per domain), so findings should be treated as preliminary.},
  keywords  = {domain adaptation, claim verification, BioMedLM, GPT-4, scientific NLP, low confidence},
}

@techreport{ross2024protocol,
  author      = {Ross, Eleanor and Tran, Minh and Obi, Chukwuemeka},
  title       = {A Structured Evidence Matrix Protocol for {LLM}-Assisted Literature Review: Design and Pilot Evaluation},
  institution = {Centre for Research Methodology, University of Edinburgh},
  year        = {2024},
  number      = {CRM-2024-07},
  url         = {https://www.ed.ac.uk/files/atoms/files/crm-2024-07-evidence-matrix-protocol.pdf},
  abstract    = {We describe and pilot-evaluate a structured evidence matrix protocol for LLM-assisted literature review at a single institution (n=8 research teams). Teams using the structured protocol registered 73% fewer duplicate claims compared to unstructured note-taking. Limitation: single-group design with no control condition; observational, not experimental.},
  keywords    = {evidence matrix, structured protocol, literature review, LLM, research methodology, pilot study},
}

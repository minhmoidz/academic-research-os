@inproceedings{nguyen2024sigir,
  author    = {Nguyen, Thi Lan and Castellanos, Marco and Park, Ji-Young},
  title     = {Benchmarking {LLM} Screeners on Heterogeneous Systematic Review Topics},
  booktitle = {Proceedings of the 47th International ACM SIGIR Conference on
               Research and Development in Information Retrieval},
  year      = {2024},
  pages     = {1893--1903},
  address   = {Washington, D.C., USA},
  publisher = {ACM},
  doi       = {10.1145/3626772.3657901},
  url       = {https://dl.acm.org/doi/10.1145/3626772.3657901},
  abstract  = {We construct a benchmark of 10 systematic review topics spanning
               5 domains (biomedical, CS, education, law, social science) and
               evaluate 4 LLM screeners (GPT-4, Claude-3, Gemini Pro, Llama-3-70B).
               GPT-4 achieves highest mean recall@95precision of 0.89, but
               performance varies substantially across domains (range: 0.74-0.97).
               Prompts, datasets, and evaluation code are publicly released.},
  keywords  = {benchmarking, LLM, literature screening, recall, precision,
               systematic review, heterogeneous domains, SIGIR},
}

@inproceedings{morrison2024cochrane,
  author    = {Morrison, Alicia R. and Fadel, George E. and Yamamoto, Keiko},
  title     = {Accuracy of {LLM}-Assisted Screening in {Cochrane} Systematic
               Reviews: A Validation Study},
  booktitle = {Cochrane Database of Systematic Reviews},
  year      = {2024},
  number    = {4},
  pages     = {MR000077},
  publisher = {Cochrane},
  doi       = {10.1002/14651858.MR000077},
  url       = {https://www.cochranelibrary.com/cdsr/doi/10.1002/14651858.MR000077},
  abstract  = {We validate GPT-4 and Claude-3 Opus as screening assistants on 3
               completed Cochrane systematic reviews (combined 2,150 candidate
               records). Using the published inclusion lists as ground truth, GPT-4
               misses 3/142 included studies (recall 0.979) and Claude-3 misses
               5/142 (recall 0.965). Both models over-include at roughly 3x the
               human reviewer rate. Individual missed papers are documented and
               categorized by failure mode.},
  keywords  = {Cochrane, systematic review, GPT-4, Claude-3, LLM, validation,
               recall, false negative, literature screening},
}


% JOURNAL ARTICLES
% =============================================================================

@article{thomas2024llmscreen,
  author    = {Thomas, Sarah J. and Okafor, Emmanuel and Lindqvist, Anna},
  title     = {{LLMScreen}: Evaluating {GPT}-4 for Automated Title-Abstract Screening
               in Systematic Reviews},
  journal   = {JMIR Medical Informatics},
  volume    = {12},
  number    = {3},
  year      = {2024},
  pages     = {e52841},
  doi       = {10.2196/52841},
  url       = {https://medinform.jmir.org/2024/3/e52841},
  abstract  = {We evaluate GPT-4 (version gpt-4-0613) as a title-abstract screener
               on 1,240 candidate papers from three Cochrane systematic reviews.
               GPT-4 achieves recall of 0.97 compared to 0.94 for a two-person human
               expert panel, with precision of 0.61 vs. 0.79. The full prompting
               strategy and inclusion criteria encoding are provided. Cost per paper
               was USD 0.003, compared to USD 0.45 per paper for human screening.},
  keywords  = {LLM, GPT-4, systematic review, literature screening, Cochrane,
               recall, precision, automation},
}

@article{wang2023chatgpt,
  author    = {Wang, Fang and Petrova, Irina and Al-Khafaji, Hasan},
  title     = {{ChatGPT} as a Literature Screening Assistant: A Comparative Study
               in Cardiology Systematic Reviews},
  journal   = {Systematic Reviews},
  volume    = {12},
  number    = {1},
  year      = {2023},
  pages     = {214},
  doi       = {10.1186/s13643-023-02372-y},
  url       = {https://systematicreviewsjournal.biomedcentral.com/articles/10.1186/s13643-023-02372-y},
  abstract  = {We compare ChatGPT (GPT-3.5-turbo) to a human expert screening panel
               on 823 candidate abstracts from a cardiology systematic review.
               Inter-rater agreement (Cohen's kappa) between ChatGPT and expert
               consensus was 0.76. ChatGPT missed 4 of 67 included papers (recall
               0.94) and incorrectly included 31 papers (precision 0.68). We
               discuss implications for hybrid human-LLM screening workflows.},
  keywords  = {ChatGPT, GPT-3.5, literature screening, systematic review, cardiology,
               Cohen's kappa, human-AI comparison},
}

@article{li2024asreview,
  author    = {Li, Mingzhe and van den Berg, Rens W. and Brouwer, Sophie},
  title     = {Integrating Large Language Models into {ASReview}: Performance
               and Reproducibility across Four Review Datasets},
  journal   = {Journal of Informetrics},
  volume    = {18},
  number    = {2},
  year      = {2024},
  pages     = {101489},
  doi       = {10.1016/j.joi.2024.101489},
  url       = {https://www.sciencedirect.com/science/article/pii/S1751157724000234},
  abstract  = {We integrate GPT-4 and Llama-2-70B into ASReview, an open-source
               active learning tool for systematic review screening. Evaluated on
               four benchmark datasets (PTSD, Virus, Software, Needle), GPT-4
               achieves Work Saved over Sampling (WSS@95) of 0.71 vs. 0.68 for
               the previous best model. Reproducibility across 5 independent runs
               shows coefficient of variation below 2.3% for all metrics. Code
               and prompts are released openly.},
  keywords  = {ASReview, LLM, GPT-4, Llama, active learning, reproducibility,
               systematic review, WSS@95},
}

